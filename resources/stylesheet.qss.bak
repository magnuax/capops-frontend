/** --- Base --- */
QLabel
{
    color: black;
}

QMainWindow 
{ 
    background: rgb(246, 246, 246);
}


/** --- Tab Widget --- */
QTabBar
{
    border: none;
    background: transparent;
}

QTabBar::tab
{
    min-width: 100px;
    background: rgba(0, 0, 0, 0.12);
    border-radius: 8px;
    border-bottom-left-radius: 0px;
    border-bottom-right-radius: 0px;
    border: none;
    padding: 6px 16px;
    font-size: 15px;
    color: rgb(60, 60, 60);
}

QTabBar::tab:selected
{
    background: rgb(225, 225, 225);
    color: rgb(20, 20, 20);
    font-weight: bold;
}

QTabBar::tab:!selected
{
    margin-top: 8px;
    background: rgba(0, 0, 0, 0.2);
}

QTabBar::tab:hover:!selected
{
    background: rgba(0,0,0,0.08);
}

QTabWidget::pane
{
    border: none;
    background: rgb(225,225,225);
    border-radius: 8px;
    border-top-left-radius: 0px;
}

/** --- Grid panel --- */
#GridContainer
{
    border: none;
    background: rgb(225,225,225);
    border-radius: 8px;
    border-top-left-radius: 0px;
    padding: 8px
}

/** --- Sector details panel --- */
#SectorStatusWidget, 
#AircraftListWidget, 
#SelectedAircraftWidget
{
    background: rgba(0, 0, 0, 0.07);
    border-radius: 8px;
    padding: 10px;
    border: 1px solid rgba(0, 0, 0, 0.1);
}

#SectorStatusWidget QLabel,
#AircraftListWidget QLabel,
#SelectedAircraftWidget QLabel
{
    font-size: 15px;
    color: rgb(40, 40, 40);
}

/** --- Aircraft list --- */
#AircraftListWidget QListWidget
{
    background: transparent;
    border: none;
    padding: 4px;
}

#AircraftListWidget QListWidget::item
{
    padding: 8px 6px;
    border-radius: 6px;
    color: rgb(40, 40, 40);
}

#AircraftListWidget QListWidget::item:selected
{
    background: rgba(0, 110, 180, 0.25);
    color: rgb(20, 20, 20);
}

#AircraftListWidget QListWidget::item:hover:!selected {
    background: rgba(0, 110, 180, 0.12);
    color: rgb(20, 20, 20);
}

#AircraftListWidget QListWidget::item:hover:selected {
    background: rgba(0, 110, 180, 0.38);
    color: rgb(20, 20, 20);
}

/** --- Alert buttons --- */

/** DEFAULT STATE */
AlertButton
{
    background-color: rgb(255, 128, 128);
    border-radius: 4px;
    padding: 8px;
}

#alertLabel
{
    color: black;
    font-size: 16px;
    font-weight: bold;
    background-color: transparent;
    border: none;
}

#acknowledgeButton
{
    background-color: rgb(255, 35, 35);
    color: white;
    font-weight: bold;
    font-size: 14px;
    border-radius: 4px;
    padding: 6px 12px;
}

#acknowledgeButton:hover
{
    background-color: rgb(255, 81, 81);
}

#acknowledgeButton:pressed
{
    background-color: rgb(255, 0, 0);
}

/** CONGESTED */
AlertButton[riskState="Congested"] {
    border: 1px solid rgb(180, 20, 20);
    background-color: rgb(255, 90, 90);
}

#acknowledgeButton[riskState="Congested"]
{
    border: 1px solid rgb(180   , 0, 0);
    background-color: rgb(226, 40, 40);
}

#acknowledgeButton:hover[riskState="Congested"]
{
    background-color: rgb(255, 48, 48);
}

#acknowledgeButton:pressed[riskState="Congested"]
{
    background-color: rgb(196, 0, 0);
}

/** AT RISK */
AlertButton[riskState="At Risk"] {
    background-color: rgb(255, 156, 0);
    border: 1px solid rgb(200, 90, 0);
}

#acknowledgeButton[riskState="At Risk"]
{
    background-color: rgb(255, 120, 0);
    border: 1px solid rgb(200, 90, 0);
}

#acknowledgeButton:hover[riskState="At Risk"]
{
    background-color: rgb(255, 140, 0);
}

#acknowledgeButton:pressed[riskState="At Risk"]
{
    background-color: rgb(230, 100, 0);
}
